# ------------------------------
# CS2 server
# ------------------------------
SRCDS_TOKEN=
CS2_SERVERNAME="CS2 MatchZy Server"
CS2_RCONPW=
CS2_PW=
CS2_MAXPLAYERS=10
CS2_STARTMAP=de_mirage
CS2_PORT=27015
TV_PORT=27020
CS2_ADDITIONAL_ARGS=

# ------------------------------
# Mod installer
# ------------------------------
METAMOD_VERSION=latest
MATCHZY_VERSION=latest
MOD_REINSTALL=0

# ------------------------------
# Databases / cache
# ------------------------------
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=get5
MARIADB_USER=get5
MARIADB_PASSWORD=
REDIS_PASSWORD=

# ------------------------------
# G5API
# ------------------------------
# DBKEY must be 16, 24 or 32 characters for G5API encryption.
DBKEY=
SHAREDSECRET=
STEAMAPIKEY=
HOSTNAME=https://api.example.com
CLIENTHOME=https://panel.example.com
APIURL=https://api.example.com
G5V_API_URL=
ADMINS=
SUPERADMINS=76561198000000000
LOCALLOGINS=true
UPLOADDEMOS=true
REDISTTL=86400
USEREDIS=true
QUEUETTL=3600
SERVERPINGTO=5000
SERVERPROVIDER=local

# ------------------------------
# Host ports (fixed in docker-compose.yml)
# 27015: CS2 game (tcp/udp)
# 27016: MariaDB (localhost only)
# 27017: Redis (localhost only)
# 27018: G5API
# 27019: G5V panel
# 27020: CS TV (udp, reserved)
# ------------------------------
