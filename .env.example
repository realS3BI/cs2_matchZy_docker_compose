# ------------------------------
# CS2 server
# ------------------------------
SRCDS_TOKEN=
CS2_SERVERNAME="CS2 MatchZy Server"
CS2_RCONPW=
CS2_PW=
CS2_MAXPLAYERS=10
CS2_STARTMAP=de_mirage
CS2_PORT=27015
TV_PORT=27020
CS2_ADDITIONAL_ARGS=

# ------------------------------
# Mod installer
# ------------------------------
METAMOD_VERSION=latest
MATCHZY_VERSION=latest
COUNTERSTRIKESHARP_VERSION=latest
FAKE_RCON_ENABLED=1
FAKE_RCON_VERSION=latest
WEAPONPAINTS_ENABLED=1
WEAPONPAINTS_VERSION=latest
FORTNITE_EMOTES_ENABLED=1
FORTNITE_EMOTES_VERSION=latest
FORTNITE_EMOTES_WORKSHOP_ADDON_ID=3328582199
MULTIADDONMANAGER_VERSION=latest
RAYTRACE_VERSION=latest
# Comma-separated Steam Workshop map links or IDs.
# Examples:
# CS2_WORKSHOP_MAPS=https://steamcommunity.com/sharedfiles/filedetails/?id=3070244462, https://steamcommunity.com/sharedfiles/filedetails/?id=3077265396
# CS2_WORKSHOP_MAPS=3070244462,3077265396
CS2_WORKSHOP_MAPS=
# Force MultiAddonManager to check/download mounted workshop addons on every map load.
CS2_WORKSHOP_FORCE_DOWNLOAD=0
EXECUTES_ENABLED=1
EXECUTES_VERSION=latest
SIMPLEADMIN_ENABLED=1
SIMPLEADMIN_VERSION=latest
PLAYERSETTINGS_VERSION=latest
ANYBASELIB_VERSION=latest
MENUMANAGER_VERSION=latest
MATCHZY_SMOKE_COLOR=0
# Optional MatchZy chat prefix override.
# Priority: MATCHZY_CHAT_PREFIX > matchzy_chat_prefix > CS2_SERVERNAME.
# Plain text will be wrapped as {Green}<value>{Default}.
# Leave empty to fall back to CS2_SERVERNAME.
MATCHZY_CHAT_PREFIX=
# Legacy alias for compatibility (same behavior as MATCHZY_CHAT_PREFIX).
matchzy_chat_prefix=
# Comma-separated Steam64IDs, spaces around commas are allowed.
# Example: ADMINS=76561198000000001, 76561198000000002
ADMINS=
MOD_REINSTALL=0

# ------------------------------
# Host ports (fixed in docker-compose.yml)
# 27015: CS2 game (tcp/udp)
# 27020: CS TV (udp, reserved)
# ------------------------------
